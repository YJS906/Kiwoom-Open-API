APP_NAME=Kiwoom Readonly Dashboard
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

KIWOOM_ENV=mock
KIWOOM_APP_KEY=YOUR_KIWOOM_APP_KEY
KIWOOM_SECRET_KEY=YOUR_KIWOOM_SECRET_KEY
KIWOOM_ACCOUNT_NO=YOUR_10_DIGIT_MOCK_ACCOUNT_NUMBER

# Optional: use a separate production read-only market key for live market-wide
# features such as the realtime 52-week-high panel. Leave these blank if you
# only want the mock dashboard.
KIWOOM_MARKET_ENV=mock
KIWOOM_MARKET_APP_KEY=
KIWOOM_MARKET_SECRET_KEY=

KIWOOM_TIMEOUT_SECONDS=15
KIWOOM_SYMBOL_CACHE_TTL_SECONDS=21600
KIWOOM_CHART_CACHE_TTL_SECONDS=300
KIWOOM_QUOTE_CACHE_TTL_SECONDS=5
KIWOOM_ACCOUNT_CACHE_TTL_SECONDS=30
NEWS_CACHE_TTL_SECONDS=60

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NEWS_PROVIDER=auto

# Strategy safety flags. Keep these defaults until you fully verify the system.
TRADING_CONFIG_PATH=./config.yaml
AUTO_BUY_ENABLED=false
PAPER_TRADING=true
USE_MOCK_ONLY=true
MOCK_ORDER_ENABLED=false
REAL_ORDER_ENABLED=false

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
